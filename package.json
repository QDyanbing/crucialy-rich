{
  "name": "crucialy-rich",
  "version": "0.0.0",
  "description": "Self-hosted rich text editor kernel and React component workspace.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@8.6.11",
  "engines": {
    "node": ">=22.14.0 <23",
    "pnpm": ">=8.6.11 <9"
  },
  "volta": {
    "node": "22.14.0",
    "pnpm": "8.6.11"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "check:all": "pnpm check && pnpm test:e2e",
    "clean": "node ./scripts/clean.mjs",
    "dev": "pnpm --filter @crucialy-rich/demo dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "hooks:install": "git config core.hooksPath .githooks",
    "lint": "eslint . --max-warnings=0",
    "preinstall": "node ./scripts/verify-package-manager.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:install:deps": "playwright install --with-deps chromium",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false"
  },
  "lint-staged": {
    "*.{css,html,json,md,yaml,yml}": "prettier --check",
    "*.{js,mjs,cjs,ts,tsx}": [
      "prettier --check",
      "eslint --max-warnings=0"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@eslint/js": "9.28.0",
    "@playwright/test": "1.52.0",
    "@types/node": "22.15.29",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.6.0",
    "eslint": "9.28.0",
    "eslint-config-prettier": "10.1.5",
    "globals": "14.0.0",
    "jsdom": "29.1.1",
    "lint-staged": "15.5.2",
    "prettier": "3.5.3",
    "tsup": "8.5.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.33.1",
    "vite": "6.3.5",
    "vitest": "3.2.4"
  }
}
