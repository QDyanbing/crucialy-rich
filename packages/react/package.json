{
  "name": "@crucialy-rich/react",
  "version": "0.0.0",
  "description": "React bindings for the crucialy-rich editor kernel.",
  "keywords": [
    "rich-text",
    "editor",
    "wysiwyg",
    "react",
    "crucialy-rich"
  ],
  "homepage": "https://github.com/QDyanbing/crucialy-rich/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/QDyanbing/crucialy-rich/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QDyanbing/crucialy-rich.git",
    "directory": "packages/react"
  },
  "license": "MIT",
  "author": "QDyanbing",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false"
  },
  "dependencies": {
    "@crucialy-rich/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  }
}
