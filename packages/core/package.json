{
  "name": "@crucialy-rich/core",
  "version": "0.0.0",
  "description": "Self-hosted rich text editor kernel for crucialy-rich.",
  "keywords": [
    "rich-text",
    "editor",
    "wysiwyg",
    "kernel",
    "crucialy-rich"
  ],
  "homepage": "https://github.com/QDyanbing/crucialy-rich/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/QDyanbing/crucialy-rich/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QDyanbing/crucialy-rich.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "author": "QDyanbing",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --tsconfig tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false"
  }
}
